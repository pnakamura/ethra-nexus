# ============================================================
# ETHRA NEXUS — Variáveis de ambiente
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o arquivo .env
# ============================================================

# === APLICAÇÃO ===
NODE_ENV=development
APP_URL=http://localhost:3000
APP_SECRET=change-this-to-a-random-64-char-string

# === SUPABASE ===
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# === AI PROVIDERS ===

# Anthropic — provider primário para dados sensíveis (LGPD)
ANTHROPIC_API_KEY=sk-ant-...

# OpenRouter — gateway multi-provider (Groq, Gemini, etc.)
# Usado para módulos operacionais de menor custo
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# OpenAI — usado APENAS para embeddings (text-embedding-3-small)
# Se não configurado, embeddings usarão OpenRouter como fallback
OPENAI_API_KEY=sk-...

# === ROTEAMENTO DE PROVIDERS POR MÓDULO ===
# Formato: NEXUS_PROVIDER_[MODULO]=[provider]:[modelo]
# Valores padrão já configurados no ProviderRegistry — só sobrescreva se necessário
# NEXUS_PROVIDER_AIOS_MASTER=anthropic:claude-sonnet-4-6
# NEXUS_PROVIDER_WIKI_INGEST=anthropic:claude-sonnet-4-6
# NEXUS_PROVIDER_WIKI_QUERY=anthropic:claude-sonnet-4-6
# NEXUS_PROVIDER_WIKI_LINT=openrouter:groq/llama-3.1-8b-instant
# NEXUS_PROVIDER_AGENT_ATENDIMENTO=anthropic:claude-sonnet-4-6
# NEXUS_PROVIDER_AGENT_MONITORAMENTO=openrouter:groq/llama-3.1-8b-instant

# === N8N ===
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-this-password
N8N_ENCRYPTION_KEY=change-this-to-a-random-32-char-string
N8N_HOST=localhost
N8N_PORT=5678

# === SILVERBULLET (Wiki UI) ===
SB_USER=admin:change-this-password
SB_PORT=3001

# === EVOLUTION API (WhatsApp) — opcional ===
# EVOLUTION_API_URL=https://[vps-ip]:8080
# EVOLUTION_API_KEY=change-this-key

# === SMTP (Alertas por email) — opcional ===
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=no-reply@example.com
# SMTP_PASS=
# SMTP_FROM=Ethra Nexus <no-reply@example.com>

# === MODO CLOUD (multi-tenant) ===
# Deixe vazio para self-hosted (single tenant)
# NEXUS_CLOUD_MODE=true
# NEXUS_TENANT_ISOLATION=rls   # rls | schema

# === DEPLOYMENT ===
# EASYPANEL_APP_NAME=ethra-nexus
