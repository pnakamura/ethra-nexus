# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
.next/
out/

# Turbo cache
.turbo/

# Environment — NEVER commit
.env
.env.local
.env.*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Test coverage
coverage/
playwright-report/
test-results/

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/settings.json
.idea/
*.swp
*.swo

# Supabase local dev
supabase/.branches
supabase/.temp

# Wiki raw sources — client content, not versioned
wikis/*/raw/
!wikis/*/raw/.gitkeep

# Docker volumes (local)
infra/docker/volumes/

# Secrets — NEVER commit
*.pem
*.key
*.p12
*.crt
infra/docker/secrets/*.txt
infra/docker/nginx/ssl/
!infra/docker/secrets/README.md
!infra/docker/secrets/.gitkeep
infra/vps/secrets/*.txt
infra/vps/secrets/*.enc
infra/vps/secrets/encrypted/
!infra/vps/secrets/manage-keys.sh
!infra/vps/secrets/.gitkeep
