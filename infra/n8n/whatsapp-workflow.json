{
  "name": "WhatsApp — Ethra Nexus",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "whatsapp",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "node-webhook",
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [200, 400],
      "webhookId": "ethra-whatsapp-handler"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst data = body?.data;\n\nif (!data || data.key?.fromMe) return [];\n\nconst text = (\n  data.message?.conversation ||\n  data.message?.extendedTextMessage?.text ||\n  ''\n).trim();\n\nif (!text) return [];\n\nconst from = data.key?.remoteJid || '';\nconst args = text.split(' ').slice(1).join(' ');\n\nlet replyText = '';\nlet needsSearch = false;\nlet searchQuery = '';\n\nif (text.startsWith('/ajuda')) {\n  replyText =\n    '🤖 *Ethra Nexus — Comandos disponíveis*\\n\\n' +\n    '/ajuda — esta mensagem\\n' +\n    '/status — status do sistema\\n' +\n    '/agentes — lista de agentes ativos\\n' +\n    '/buscar [termo] — busca na wiki\\n' +\n    '/aprovar [id] — aprova uma tarefa pendente';\n\n} else if (text.startsWith('/status')) {\n  replyText = '✅ *Status Ethra Nexus*\\n\\nServidor: online\\nVersão: 1.0.0';\n\n} else if (text.startsWith('/agentes')) {\n  replyText = '🤖 *Agentes*\\n\\nIntegração em configuração. Em breve disponível.';\n\n} else if (text.startsWith('/buscar')) {\n  if (!args) {\n    replyText = '🔍 Uso: /buscar [termo]\\nEx: /buscar política de pagamento';\n  } else {\n    needsSearch = true;\n    searchQuery = args;\n  }\n\n} else if (text.startsWith('/aprovar')) {\n  replyText = args\n    ? `✅ Aprovação solicitada para: ${args}\\n\\n⚙️ Integração com tickets em configuração.`\n    : '✅ Uso: /aprovar [id-da-tarefa]';\n\n} else {\n  replyText = '❓ Comando não reconhecido.\\n\\nDigite /ajuda para ver os comandos disponíveis.';\n}\n\nreturn [{ json: { from, replyText, needsSearch, searchQuery } }];"
      },
      "id": "node-code",
      "name": "Parse Comando",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [420, 400]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.needsSearch }}",
              "value2": true
            }
          ]
        }
      },
      "id": "node-if",
      "name": "Precisa Buscar?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
