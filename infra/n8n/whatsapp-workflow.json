    {
      "parameters": {
        "method": "POST",
        "url": "https://api.nexus.ethra.com.br/api/v1/wiki/search",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $('Login API').item.json.token }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            { "name": "query", "value": "={{ $('Parse Comando').item.json.searchQuery }}" },
            { "name": "limit", "value": "3" }
          ]
        },
        "options": {}
      },
      "id": "node-search",
      "name": "Buscar Wiki",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [1080, 240]
    },
    {
      "parameters": {
        "jsCode": "const results = $input.first().json.data || [];\nconst from = $('Parse Comando').item.json.from;\nconst query = $('Parse Comando').item.json.searchQuery;\n\nif (results.length === 0) {\n  return [{ json: { from, replyText: `🔍 Nenhum resultado encontrado para: \"${query}\"` } }];\n}\n\nconst lines = results.map((r, i) =>\n  `${i + 1}. *${r.title}* (${r.type})`\n);\nconst replyText = `🔍 *Resultados para \"${query}\":*\\n\\n${lines.join('\\n')}`;\nreturn [{ json: { from, replyText } }];"
      },
      "id": "node-format",
      "name": "Formatar Resultados",
      "type": "n8n-nodes-base.code",
