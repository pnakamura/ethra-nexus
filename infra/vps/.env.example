# ============================================================
# Ethra Nexus VPS — Variáveis de ambiente
# Copie para .env e preencha TODOS os campos obrigatórios
# ============================================================

# === DOMÍNIO ===
DOMAIN=nexus.seudominio.com.br

# === POSTGRESQL ===
POSTGRES_PASSWORD=GERE_UMA_SENHA_FORTE_AQUI

# === JWT (Fastify @fastify/jwt — extrai tenantId no onRequest hook) ===
# Gere com: openssl rand -base64 32
JWT_SECRET=GERE_COM_OPENSSL_RAND_BASE64_32

# === AI PROVIDERS ===
# Crie os arquivos em ./secrets/:
#   echo "sk-ant-..." > secrets/anthropic_key.txt
#   echo "sk-or-..."  > secrets/openrouter_key.txt
#   echo "sk-..."     > secrets/openai_key.txt
#   chmod 600 secrets/*.txt

# === N8N ===
N8N_USER=admin
N8N_PASSWORD=GERE_UMA_SENHA_FORTE
N8N_ENCRYPTION_KEY=GERE_COM_OPENSSL_RAND_HEX_16

# === SILVERBULLET ===
SB_PASSWORD=GERE_UMA_SENHA_FORTE

# === SMTP (opcional — para emails de alerta) ===
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=seu@email.com
# SMTP_PASS=app_password
# SMTP_FROM=Ethra Nexus <noreply@seudominio.com.br>

# === VERSÃO ===
NEXUS_VERSION=latest
